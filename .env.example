# ==============================
# Core app settings
# ==============================
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_PUBLIC_PORT=18000
WEB_PUBLIC_PORT=15173
POSTGRES_PUBLIC_PORT=15432
REDIS_PUBLIC_PORT=16379

# ==============================
# Required Telegram settings
# ==============================
# REQUIRED for bot and Telegram auth validation
BOT_TOKEN=
# REQUIRED for referral links in Mini App
BOT_USERNAME=
# Strongly recommended for bot web_app button
MINI_APP_URL=https://your-miniapp-domain.example

# ==============================
# Auth/session
# ==============================
JWT_SECRET=change_me_super_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
ADMIN_BEARER_TOKEN=change_me_admin_token
# Optional alternative admin access via Telegram JWT:
# user with this telegram_user_id can call /admin/* with Bearer <access_token>
TELEGRAM_ADMIN_ID=

# ==============================
# PostgreSQL (must be consistent)
# ==============================
POSTGRES_DB=vpn
POSTGRES_USER=vpn
POSTGRES_PASSWORD=vpn
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vpn:vpn@postgres:5432/vpn

# ==============================
# Redis
# ==============================
REDIS_URL=redis://redis:6379/0
NOTIFICATION_QUEUE_KEY=notifications:telegram

# ==============================
# API runtime
# ==============================
CORS_ORIGINS=http://localhost:15173,http://127.0.0.1:15173
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ==============================
# Business settings
# ==============================
REFERRAL_BONUS_DAYS=7
EXPIRING_NOTIFY_DAYS=3
SCHEDULER_INTERVAL_SECONDS=120

# ==============================
# Legacy manual payment setting
# ==============================
# Deprecated: kept only for backward compatibility with older builds
PAYMENT_PHONE=+79990000000

# ==============================
# Platega acquiring
# ==============================
PLATEGA_BASE_URL=https://app.platega.io
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
# 2 = payment method from Platega docs example
PLATEGA_PAYMENT_METHOD=2

# ==============================
# 3x-ui integration
# ==============================
THREEXUI_BASE_URL=http://example.com:2053
# Optional public URL for client configs/sub-links if panel URL is internal
THREEXUI_PUBLIC_BASE_URL=
THREEXUI_USERNAME=admin
THREEXUI_PASSWORD=change_me
THREEXUI_DEFAULT_INBOUND_ID=1
THREEXUI_VERIFY_SSL=false
THREEXUI_TIMEOUT_SECONDS=15
THREEXUI_RETRY_ATTEMPTS=3

# ==============================
# Web app
# ==============================
VITE_API_BASE_URL=http://localhost:18000
# Optional: show admin section in Mini App for this Telegram user id
VITE_TELEGRAM_ADMIN_ID=
